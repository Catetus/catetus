# Rust
/target
**/*.rs.bk
Cargo.lock.bak

# Experiments tree moved to catetus/catetus-private on 2026-05-19 as part
# of the pre-public-flip open-core split. Local untracked bench artifacts
# (PLY/screenshot scratch) may still live under experiments/ for active
# development; they are not part of the public repo.
experiments/

# Node / pnpm
node_modules/
**/node_modules/
packages/*/dist/
apps/codec/*/dist/
apps/codec/*/.tsbuildinfo
packages/*/.tsbuildinfo
.pnpm-store/

# Playwright / visual harness output
tests/visual/report/
tests/visual/test-results/
tests/visual/playwright-report/
tests/visual/.cache/

# Build artifacts and prebuilt binaries
/bin/*
!/bin/.gitkeep
!/bin/README.md

# Local benchmark scratch
/benches/scratch/
/benches/runs/

# MesonGS++ codec local smoke / scratch artifacts. The harness writes
# encoded `.meson` blobs and decoded round-trip `.ply`s here; they're
# regenerable from `apps/modal-presets-local/mesonpp_smoke.py`.
/tasks/scripts/meson-out/

# Pre-v0.1.2 SplatBench scenes regenerate via `python3 benches/synth_scenes.py
# benches/scenes`; they're large (the dense proxy is 473 MB) and not committed.
# The v0.1.2 failure-mode scenes are small enough to ship as fixtures and ARE
# committed under benches/scenes/.
/benches/scenes/splatbench_product_proxy.ply
/benches/scenes/splatbench_indoor_proxy.ply
/benches/scenes/splatbench_outdoor_proxy.ply
/benches/scenes/splatbench_floater_proxy.ply
/benches/scenes/splatbench_dense_proxy.ply

# Editor / OS
.DS_Store
*.swp
*.swo
.vscode/
.idea/
*.iml

# Logs and reports left from CI runs
*.log
playwright-report/
test-results/

# Private corpus (don't track real splats)
fixtures/private/**
!fixtures/private/.gitkeep

# Local env
.env
.env.*
!.env.example

# Temporary outputs
/tmp/
/dist/
.lazyweb/
.claude/

# SplatBench fidelity frames: reproducible from
# `tests/visual/scripts/splatbench-fidelity.mjs`; metrics are committed in
# benches/reports/fidelity-v0.json. ~20 MB of PNGs that would bloat the repo.
benches/reports/frames/

# apps/web Astro build artifacts + synced data (regenerated by build)
apps/web/dist/
apps/web/.astro/
apps/web/src/data/*
# Exception: khr-conformance.json is generated by build-khr-conformance.mjs
# which requires cargo (unavailable on Vercel). The page imports this JSON
# at build time, so the last-known-good output is committed and refreshed
# locally before pushing.
!apps/web/src/data/khr-conformance.json
__pycache__/
*.pyc
.vercel

# Local progress + ad-hoc screenshots from autonomous runs.
tasks/screenshots/
.tmp/

# Viewer bench build outputs.
packages/viewer/dist-bench/

# Per-task todo dumps from agents — not durable docs.
tasks/todo.md
/benches/scenes/bonsai_mipnerf360_iter7k.ply
/benches/scenes/stump_mipnerf360_iter7k.ply
# Cluster-fly LOD ladder staging symlinks (source PLYs already excluded by
# the /benches/scenes/real/*.ply pattern below). Symlinks here for the bench
# harness to discover the scenes alongside the existing proxies.
/benches/scenes/cluster_fly_s.ply
/benches/scenes/cluster_fly_m.ply
/benches/scenes/cluster_fly_l.ply
/benches/scenes/cluster_fly_xl.ply
/benches/scenes/cluster_fly_xxl.ply
# Real scene PLYs are large (hundreds of MB) and pulled on demand by
# `benches/scenes/scripts/pull-*.sh`. Keep the directory tracked so the
# manifest.json hash + URL convention is reproducible.
/benches/scenes/real/*.ply
/benches/scenes/real/*.splat
/benches/scenes/real/*.gltf
/benches/scenes/real/*.glb
/benches/scenes/real/*.spz
/benches/scenes/real/*.sog
/benches/scenes/real/*.bin
/benches/scenes/real/*.zst

# catetus-api default local sqlite path — runtime-created.
/data/
apps/api/data/

# Blender add-on build artifacts — CI rebuilds these on every push.
integrations/blender/dist/*.zip

# novel-5 morton pre-permute bench scratch (large .bin scenes)
/.bench-scenes/

# p2-audit-v2 decoded PLY caches (~280 MB; reproducible via the Modal app)
/tasks/scripts/p2-audit-v2/results/*.ply
/tasks/scripts/p2-audit-v2/*.log


# experiments/ — research artifacts (PLY, GLB, GLTF, BIN are too big for git)
experiments/**/*.ply
experiments/**/*.glb
experiments/**/*.gltf
experiments/**/*.bin
experiments/**/*.spz
experiments/**/*.sog
experiments/**/*.npy
experiments/**/out/
experiments/**/.bench-out/
experiments/**/node_modules/
experiments/**/.venv/
experiments/RESEARCH_DOCS/*.pdf

# codecgs-lite demo: GLB assets are reproducible via
# experiments/w3-codecgs-integrate/code/pack_codecgs_glb.py
# (don't bake 8 MB binary blobs into git for a demo).
apps/web/public/codecgs-*.glb
experiments/w3-codecgs-integrate/playwright-screenshot.png
experiments/w3-codecgs-integrate/node_modules
experiments/w3-codecgs-integrate/*.glb
experiments/w3-codecgs-integrate/*.bundle/

# Auxiliary worktree directories created by parallel research agents.
# These are git worktrees holding their own checkouts; never commit them
# into the main repo as embedded git repos.
/.wt-*
/worktrees/

# jacobian-census J_per_splat.npz files >100 MB exceed GitHub's hard limit.
# Reproducible via experiments/jacobian-census-canonical-11/code/run_scene.sh;
# live on the 4090 box at
# $HOME/catetus/jacobian-census-canonical-11/out/<scene>-30k-*/.
experiments/jacobian-census-bicycle-30k/J_per_splat.npz
experiments/jacobian-census-bicycle-30k/raw_runs/*/J_per_splat.npz
experiments/jacobian-census-garden-30k/J_per_splat.npz
experiments/jacobian-census-garden-30k/raw_runs/*/J_per_splat.npz
experiments/jacobian-census-stump-30k/J_per_splat.npz
experiments/jacobian-census-stump-30k/raw_runs/*/J_per_splat.npz

# Local-only standards-outreach archive (drafts created post-private-flip,
# never to be pushed to a public remote — see PUNCH_LIST.md blocker #2).
.local/
docs/standards-outreach/
