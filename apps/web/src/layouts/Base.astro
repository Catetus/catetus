---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
// Absolute URL for OG/Twitter image. Twitter/Slack/Discord require an
// absolute URL or they silently drop the card.
const ogImage = new URL("/og-image.png", Astro.site ?? "https://catetus.com").toString();
const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://catetus.com").toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b0d10" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <!--
      Browser importmap for `@catetus/viewer` and its bare-spec dependencies.
      The compiled viewer ESM in /viewer/ uses bare specifiers (`fflate`,
      `fzstd`, `@catetus/glb-polyfill`) that browsers can't resolve on their
      own; this importmap points each at a static asset served from our
      origin. Must appear in <head> BEFORE any module import.
    -->
    <script type="importmap" set:html={`{
      "imports": {
        "fflate": "/viewer/vendor/fflate.js",
        "fzstd": "/viewer/vendor/fzstd.js",
        "@catetus/glb-polyfill": "/viewer/glb-polyfill/index.js"
      }
    }`} />
  </head>
  <body>
    <main class="page">
      <slot />
    </main>
  </body>
</html>
