---
// "Try it" is the call-to-action that proves SplatForge is alive.
// The PRIMARY action is "Choose a file" (file picker) + drop zone — the
// drop zone IS the section, not a button inside it. Secondary affordances
// (apply as design partner, view docs) live BELOW the upload card so they
// don't compete with the upload action.
// Same-origin proxy. Vercel rewrites /api/* to the actual HTTP backend
// (see apps/web/vercel.json). This avoids the browser's mixed-content
// block when the page is served over HTTPS but the backend is HTTP.
// Override via PUBLIC_API_BASE for local dev (e.g. http://127.0.0.1:8080).
const apiBase = import.meta.env.PUBLIC_API_BASE ?? "/api";
const partnerHref =
  "https://github.com/montabano1/SplatForge/issues/new?title=design-partner-interest&body=Hi%20%E2%80%94%20I%27d%20like%20to%20run%20a%20splat%20through%20SplatForge";
const supported = [".ply", ".spz", ".gltf", ".glb", ".splat"];
---

<section id="try" class="try-section" aria-labelledby="try-title">
  <div class="section-head">
    <h2 id="try-title" class="section-title">Try it on your splat</h2>
    <p class="section-sub">
      Drop a Gaussian-splat scene and we'll run the full
      upload&nbsp;→&nbsp;optimize&nbsp;→&nbsp;download round-trip against the
      hosted API
      <span class="api-status" data-api-status>
        <span class="status-dot" aria-hidden="true"></span>
        <span data-api-status-label>live</span>
      </span>.
    </p>
  </div>

  <div class="dropzone" data-uploader>
    <input
      type="file"
      id="splat-file-input"
      data-file-input
      accept=".ply,.spz,.gltf,.glb,.splat"
      hidden
    />

    <div class="dropzone-icon" aria-hidden="true">
      <svg width="56" height="56" viewBox="0 0 56 56" fill="none">
        <circle cx="28" cy="28" r="27" stroke="currentColor" stroke-width="1.5" stroke-dasharray="4 4" opacity="0.4"></circle>
        <path d="M28 18v18M21 27l7-9 7 9" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"></path>
        <path d="M15 38v3a2 2 0 002 2h22a2 2 0 002-2v-3" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"></path>
      </svg>
    </div>

    <div class="dropzone-headline" data-uploader-headline>
      Drop a splat or click to choose a file
    </div>
    <div class="dropzone-body" data-uploader-body>
      Files stay local until you confirm. Supported formats below.
    </div>

    <label for="splat-file-input" class="btn btn-primary dropzone-cta">
      <span aria-hidden="true">📎</span>&nbsp;Choose file
    </label>

    <div class="format-chips" aria-label="Supported input formats">
      {supported.map((ext) => <span class="chip">{ext}</span>)}
    </div>

    <div class="job-status" data-job-status hidden>
      <div class="job-status-row">
        <span class="job-status-label" data-job-status-label>queued</span>
        <span class="job-status-meta" data-job-status-meta></span>
      </div>
      <div class="job-progress" data-job-progress>
        <div class="job-progress-bar" data-job-progress-bar></div>
      </div>
      <div class="job-status-cta" data-job-status-cta></div>
    </div>

    <div class="result-preview" data-result-preview hidden>
      <canvas data-result-canvas class="result-canvas"></canvas>
      <div class="result-actions">
        <a class="btn btn-primary" data-result-download download>
          <span aria-hidden="true">⬇</span>&nbsp;Download .glb
        </a>
        <button type="button" class="btn btn-secondary" data-result-reset>
          Optimize another
        </button>
      </div>
    </div>
  </div>

  <div class="try-footer">
    <span class="pill">Design-partner alpha</span>
    <span class="try-footer-meta">
      Need a deeper integration or a giant scene?
      <a href={partnerHref} target="_blank" rel="noreferrer noopener"
        >Apply as design partner →</a
      >
    </span>
  </div>
</section>

<style>
  .job-status {
    margin-top: 1.25rem;
    padding: 1rem 1.1rem;
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    text-align: left;
  }
  .job-status-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.55rem;
  }
  .job-status-label {
    font-weight: 600;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .job-status-meta {
    font-size: 0.85rem;
    opacity: 0.7;
  }
  .job-progress {
    height: 6px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.07);
    overflow: hidden;
    margin-bottom: 0.85rem;
  }
  .job-progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #6366f1, #8b5cf6);
    transition: width 0.4s ease;
  }
  .job-progress.indeterminate .job-progress-bar {
    width: 38%;
    animation: job-progress-slide 1.4s ease-in-out infinite;
  }
  @keyframes job-progress-slide {
    0% {
      transform: translateX(-100%);
    }
    100% {
      transform: translateX(280%);
    }
  }
  .job-status[data-state="done"] .job-progress-bar {
    width: 100%;
    background: linear-gradient(90deg, #10b981, #34d399);
  }
  .job-status[data-state="error"] .job-progress-bar {
    width: 100%;
    background: linear-gradient(90deg, #f43f5e, #fb7185);
  }
  .job-status-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .job-status-cta a {
    text-decoration: none;
  }
  .job-status-error {
    font-size: 0.85rem;
    color: #fda4af;
    margin-top: 0.5rem;
  }
  .result-preview {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    align-items: center;
  }
  .result-canvas {
    width: 100%;
    aspect-ratio: 16 / 10;
    background: #0a0a0a;
    border-radius: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    display: block;
  }
  .result-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
  }
</style>

<script is:inline define:vars={{ apiBase, partnerHref }}>
  (function () {
    const zone = document.querySelector("[data-uploader]");
    const input = document.querySelector("[data-file-input]");
    const headline = document.querySelector("[data-uploader-headline]");
    const body = document.querySelector("[data-uploader-body]");
    const status = document.querySelector("[data-job-status]");
    const statusLabel = document.querySelector("[data-job-status-label]");
    const statusMeta = document.querySelector("[data-job-status-meta]");
    const progress = document.querySelector("[data-job-progress]");
    const cta = document.querySelector("[data-job-status-cta]");
    const preview = document.querySelector("[data-result-preview]");
    const previewCanvas = document.querySelector("[data-result-canvas]");
    const downloadLink = document.querySelector("[data-result-download]");
    const resetBtn = document.querySelector("[data-result-reset]");
    let viewerHandle = null;
    if (
      !(zone instanceof HTMLElement) ||
      !(input instanceof HTMLInputElement) ||
      !(headline instanceof HTMLElement) ||
      !(body instanceof HTMLElement) ||
      !(status instanceof HTMLElement) ||
      !(statusLabel instanceof HTMLElement) ||
      !(statusMeta instanceof HTMLElement) ||
      !(progress instanceof HTMLElement) ||
      !(cta instanceof HTMLElement)
    )
      return;

    const hot = function (e) {
      e.preventDefault();
      zone.classList.add("drag-hover");
    };
    const cool = function () {
      zone.classList.remove("drag-hover");
    };
    zone.addEventListener("dragenter", hot);
    zone.addEventListener("dragover", hot);
    zone.addEventListener("dragleave", cool);

    const bar = document.querySelector("[data-job-progress-bar]");
    function setStatus(state, label, meta, percent) {
      status.hidden = false;
      status.dataset.state = state;
      statusLabel.textContent = label;
      statusMeta.textContent = meta || "";
      progress.classList.remove("indeterminate");
      if (typeof percent === "number" && bar instanceof HTMLElement) {
        bar.style.width = Math.max(0, Math.min(100, percent)).toFixed(1) + "%";
      } else if (state === "queued" || state === "running") {
        progress.classList.add("indeterminate");
      } else if (state === "done" || state === "error") {
        if (bar instanceof HTMLElement) bar.style.width = "100%";
      }
      cta.innerHTML = "";
    }

    function formatBytes(n) {
      if (n >= 1024 * 1024 * 1024) return (n / 1024 / 1024 / 1024).toFixed(2) + " GB";
      if (n >= 1024 * 1024) return (n / 1024 / 1024).toFixed(1) + " MB";
      if (n >= 1024) return (n / 1024).toFixed(0) + " KB";
      return n + " B";
    }
    function formatEta(seconds) {
      if (!isFinite(seconds) || seconds < 0) return "";
      if (seconds < 60) return Math.ceil(seconds) + "s left";
      const m = Math.floor(seconds / 60);
      const s = Math.ceil(seconds - m * 60);
      return m + "m " + (s > 0 ? s + "s " : "") + "left";
    }

    function fail(message) {
      setStatus("error", "error", "");
      const msg = document.createElement("div");
      msg.className = "job-status-error";
      msg.textContent = message;
      cta.appendChild(msg);
      const a = document.createElement("a");
      a.href = partnerHref;
      a.target = "_blank";
      a.rel = "noopener";
      a.className = "btn btn-secondary";
      a.textContent = "Apply as design partner →";
      cta.appendChild(a);
    }

    async function ping() {
      try {
        const r = await fetch(apiBase + "/healthz", { method: "GET" });
        if (!r.ok) return false;
        const j = await r.json();
        return j && j.ok === true;
      } catch (_) {
        return false;
      }
    }

    // R2 direct upload: ask our Vercel Function for a presigned PUT URL,
    // stream the file body directly to Cloudflare R2 (no Vercel hop, no
    // mixed-content block), then hand the resulting GET URL to the
    // optimize API as `source_url`. This bypasses every payload-size
    // bottleneck and avoids egress fees on downloads.
    async function requestUploadUrl(file) {
      const r = await fetch("/api/upload-url", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({
          filename: file.name,
          contentType: file.type || "application/octet-stream",
          size: file.size,
        }),
      });
      if (!r.ok) {
        const text = await r.text();
        throw new Error("POST /api/upload-url " + r.status + " — " + text);
      }
      return await r.json();
    }

    function uploadBytes(uploadUrl, file, contentType, onProgress) {
      return new Promise(function (resolve, reject) {
        const xhr = new XMLHttpRequest();
        xhr.open("PUT", uploadUrl, true);
        xhr.setRequestHeader("content-type", contentType);
        xhr.upload.onprogress = function (e) {
          if (e.lengthComputable) onProgress(e.loaded, e.total);
        };
        xhr.onload = function () {
          if (xhr.status >= 200 && xhr.status < 300) resolve();
          else reject(new Error("upload " + xhr.status + " — " + xhr.responseText));
        };
        xhr.onerror = function () { reject(new Error("upload failed (network)")); };
        xhr.onabort = function () { reject(new Error("upload aborted")); };
        xhr.send(file);
      });
    }

    async function createJob(sourceUrl) {
      const r = await fetch(apiBase + "/v1/jobs", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({
          preset: "web-mobile",
          source_url: sourceUrl,
        }),
      });
      if (!r.ok) {
        const text = await r.text();
        throw new Error("POST /v1/jobs " + r.status + " — " + text);
      }
      return await r.json();
    }

    async function pollJob(jobId) {
      const r = await fetch(apiBase + "/v1/jobs/" + jobId, { method: "GET" });
      if (!r.ok) {
        const text = await r.text();
        throw new Error("GET /v1/jobs/" + jobId + " " + r.status + " — " + text);
      }
      return await r.json();
    }

    function renderJob(job) {
      const s = job.status;
      if (s === "awaiting-upload" || s === "uploading") {
        setStatus("running", "processing", "preparing scene");
      } else if (s === "queued") {
        setStatus("running", "processing", "queued for optimize");
      } else if (s === "running") {
        setStatus("running", "processing", "optimizing");
      } else if (s === "done") {
        setStatus("done", "done", "ready to view", 100);
        void showPreview(job);
      } else if (s === "error") {
        fail(job.error || "optimize failed");
      }
    }

    async function showPreview(job) {
      if (!(preview instanceof HTMLElement) || !(previewCanvas instanceof HTMLCanvasElement) || !(downloadLink instanceof HTMLAnchorElement)) {
        return;
      }
      // Wire the download button (.glb is the single-file artifact users take elsewhere).
      if (job.output_url) {
        downloadLink.href = job.output_url;
        const safeName = (job.filename || "optimized").replace(/\.[^.]*$/, "");
        downloadLink.setAttribute("download", safeName + ".glb");
      }
      preview.hidden = false;
      // Mount the splatforge viewer on the canvas using the preview manifest URL.
      // The viewer streams chunks from the absolute buffer URIs baked into the manifest.
      if (!job.preview_url) {
        statusMeta.textContent = "(preview not available — download to view)";
        return;
      }
      try {
        const mod = await import(/* @vite-ignore */ "/viewer/index.js");
        const rect = previewCanvas.getBoundingClientRect();
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        previewCanvas.width = Math.max(1, Math.floor(rect.width * dpr));
        previewCanvas.height = Math.max(1, Math.floor(rect.height * dpr));
        if (viewerHandle && typeof viewerHandle.dispose === "function") {
          try { viewerHandle.dispose(); } catch (_) {}
        }
        const v = new mod.SplatForgeViewer({
          canvas: previewCanvas,
          src: job.preview_url,
          cameraPath: "orbit-8",
          budget: "web-mobile",
          autoRotate: true,
          autoRotateSpeed: 7,
        });
        v.on("firstRender", function () {
          statusMeta.textContent = "live preview";
        });
        v.on("error", function (p) {
          statusMeta.textContent = "preview failed (" + ((p && p.code) || "unknown") + ")";
        });
        await v.load();
        viewerHandle = v;
      } catch (err) {
        statusMeta.textContent = "preview failed: " + ((err && err.message) || err);
      }
    }

    function resetUploader() {
      if (viewerHandle && typeof viewerHandle.dispose === "function") {
        try { viewerHandle.dispose(); } catch (_) {}
        viewerHandle = null;
      }
      if (preview instanceof HTMLElement) preview.hidden = true;
      if (status instanceof HTMLElement) status.hidden = true;
      headline.textContent = "Drop a splat or click to choose a file";
      body.textContent = "Files stay local until you confirm. Supported formats below.";
    }

    if (resetBtn instanceof HTMLButtonElement) {
      resetBtn.addEventListener("click", resetUploader);
    }

    function waitFor(jobId) {
      return new Promise(function (resolve, reject) {
        const started = Date.now();
        const tick = async function () {
          try {
            const job = await pollJob(jobId);
            renderJob(job);
            if (job.status === "done" || job.status === "error") {
              resolve(job);
              return;
            }
            if (Date.now() - started > 10 * 60 * 1000) {
              reject(new Error("timed out waiting for job (10 min)"));
              return;
            }
            setTimeout(tick, 2000);
          } catch (err) {
            reject(err);
          }
        };
        tick();
      });
    }

    async function handleFile(file) {
      const supportedExts = [".ply", ".spz", ".gltf", ".glb", ".splat"];
      const lower = file.name.toLowerCase();
      const ok = supportedExts.some(function (ext) {
        return lower.endsWith(ext);
      });
      if (!ok) {
        headline.textContent = "Unsupported file type.";
        body.innerHTML =
          'Supported: <code>' +
          supportedExts.join("</code>, <code>") +
          "</code>. Choose a different file.";
        return;
      }
      headline.textContent = "Uploading " + file.name;
      body.innerHTML = formatBytes(file.size);
      setStatus("uploading", "uploading", "starting…", 0);

      try {
        const reachable = await ping();
        if (!reachable) throw new Error("the optimize service is unreachable");
        const signed = await requestUploadUrl(file);
        const uploadStart = Date.now();
        let lastEtaUpdate = 0;
        await uploadBytes(signed.uploadUrl, file, signed.contentType,
          function (loaded, total) {
            const now = Date.now();
            const elapsed = Math.max(0.001, (now - uploadStart) / 1000);
            const bps = loaded / elapsed;
            const pct = total > 0 ? (loaded / total) * 100 : 0;
            if (now - lastEtaUpdate < 200) return;
            lastEtaUpdate = now;
            const remaining = total > 0 && bps > 0 ? (total - loaded) / bps : Infinity;
            const meta =
              pct.toFixed(0) + "%  ·  " +
              (bps / 1024 / 1024).toFixed(1) + " MB/s  ·  " +
              formatEta(remaining);
            setStatus("uploading", "uploading", meta, pct);
          });
        setStatus("running", "processing", "starting optimize", 0);
        const job = await createJob(signed.sourceUrl);
        headline.textContent = "Optimizing " + file.name;
        body.innerHTML = "Job " + job.id;
        await waitFor(job.id);
      } catch (err) {
        headline.textContent = "Something went wrong.";
        body.innerHTML = "The hosted API may be cold or the file too large.";
        const apiStatus = document.querySelector("[data-api-status]");
        const apiStatusLbl = document.querySelector("[data-api-status-label]");
        if (apiStatus && apiStatusLbl) {
          apiStatus.classList.add("offline");
          apiStatusLbl.textContent = "offline";
        }
        fail((err && err.message) ? err.message : String(err));
      }
    }

    zone.addEventListener("drop", function (e) {
      e.preventDefault();
      cool();
      const file =
        e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
      if (file) void handleFile(file);
    });
    input.addEventListener("change", function () {
      const file = input.files && input.files[0];
      if (file) void handleFile(file);
    });
  })();
</script>
