---
// "Try it" is the call-to-action that proves SplatForge is alive.
// The PRIMARY action is "Choose a file" (file picker) + drop zone — the
// drop zone IS the section, not a button inside it. Secondary affordances
// (apply as design partner, view docs) live BELOW the upload card so they
// don't compete with the upload action.
// Same-origin proxy. Vercel rewrites /api/* to the actual HTTP backend
// (see apps/web/vercel.json). This avoids the browser's mixed-content
// block when the page is served over HTTPS but the backend is HTTP.
// Override via PUBLIC_API_BASE for local dev (e.g. http://127.0.0.1:8080).
const apiBase = import.meta.env.PUBLIC_API_BASE ?? "/api";
const partnerHref =
  "https://github.com/montabano1/SplatForge/issues/new?title=design-partner-interest&body=Hi%20%E2%80%94%20I%27d%20like%20to%20run%20a%20splat%20through%20SplatForge";
const supported = [".ply", ".spz", ".gltf", ".glb", ".splat"];
---

<section id="try" class="try-section" aria-labelledby="try-title">
  <div class="section-head">
    <h2 id="try-title" class="section-title">Try it on your splat</h2>
    <p class="section-sub">
      Drop a Gaussian-splat scene and we'll run the full
      upload&nbsp;→&nbsp;optimize&nbsp;→&nbsp;download round-trip against the
      hosted API
      <span class="api-status" data-api-status>
        <span class="status-dot" aria-hidden="true"></span>
        <span data-api-status-label>live</span>
      </span>.
    </p>
  </div>

  <div class="dropzone" data-uploader>
    <input
      type="file"
      id="splat-file-input"
      data-file-input
      accept=".ply,.spz,.gltf,.glb,.splat"
      hidden
    />

    <div class="dropzone-icon" aria-hidden="true">
      <svg width="56" height="56" viewBox="0 0 56 56" fill="none">
        <circle cx="28" cy="28" r="27" stroke="currentColor" stroke-width="1.5" stroke-dasharray="4 4" opacity="0.4"></circle>
        <path d="M28 18v18M21 27l7-9 7 9" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"></path>
        <path d="M15 38v3a2 2 0 002 2h22a2 2 0 002-2v-3" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"></path>
      </svg>
    </div>

    <div class="dropzone-headline" data-uploader-headline>
      Drop a splat or click to choose a file
    </div>
    <div class="dropzone-body" data-uploader-body>
      Files stay local until you confirm. Supported formats below.
    </div>

    <label for="splat-file-input" class="btn btn-primary dropzone-cta">
      <span aria-hidden="true">📎</span>&nbsp;Choose file
    </label>

    <div class="format-chips" aria-label="Supported input formats">
      {supported.map((ext) => <span class="chip">{ext}</span>)}
    </div>

    <div class="job-status" data-job-status hidden>
      <div class="job-status-row">
        <span class="job-status-label" data-job-status-label>queued</span>
        <span class="job-status-meta" data-job-status-meta></span>
      </div>
      <div class="job-progress" data-job-progress>
        <div class="job-progress-bar" data-job-progress-bar></div>
      </div>
      <div class="job-status-cta" data-job-status-cta></div>
    </div>
  </div>

  <div class="try-footer">
    <span class="pill">Design-partner alpha</span>
    <span class="try-footer-meta">
      Need a deeper integration or a giant scene?
      <a href={partnerHref} target="_blank" rel="noreferrer noopener"
        >Apply as design partner →</a
      >
    </span>
  </div>
</section>

<style>
  .job-status {
    margin-top: 1.25rem;
    padding: 1rem 1.1rem;
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    text-align: left;
  }
  .job-status-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.55rem;
  }
  .job-status-label {
    font-weight: 600;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .job-status-meta {
    font-size: 0.85rem;
    opacity: 0.7;
  }
  .job-progress {
    height: 6px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.07);
    overflow: hidden;
    margin-bottom: 0.85rem;
  }
  .job-progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #6366f1, #8b5cf6);
    transition: width 0.4s ease;
  }
  .job-progress.indeterminate .job-progress-bar {
    width: 38%;
    animation: job-progress-slide 1.4s ease-in-out infinite;
  }
  @keyframes job-progress-slide {
    0% {
      transform: translateX(-100%);
    }
    100% {
      transform: translateX(280%);
    }
  }
  .job-status[data-state="done"] .job-progress-bar {
    width: 100%;
    background: linear-gradient(90deg, #10b981, #34d399);
  }
  .job-status[data-state="error"] .job-progress-bar {
    width: 100%;
    background: linear-gradient(90deg, #f43f5e, #fb7185);
  }
  .job-status-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .job-status-cta a {
    text-decoration: none;
  }
  .job-status-error {
    font-size: 0.85rem;
    color: #fda4af;
    margin-top: 0.5rem;
  }
</style>

<script is:inline define:vars={{ apiBase, partnerHref }}>
  (function () {
    const zone = document.querySelector("[data-uploader]");
    const input = document.querySelector("[data-file-input]");
    const headline = document.querySelector("[data-uploader-headline]");
    const body = document.querySelector("[data-uploader-body]");
    const status = document.querySelector("[data-job-status]");
    const statusLabel = document.querySelector("[data-job-status-label]");
    const statusMeta = document.querySelector("[data-job-status-meta]");
    const progress = document.querySelector("[data-job-progress]");
    const cta = document.querySelector("[data-job-status-cta]");
    if (
      !(zone instanceof HTMLElement) ||
      !(input instanceof HTMLInputElement) ||
      !(headline instanceof HTMLElement) ||
      !(body instanceof HTMLElement) ||
      !(status instanceof HTMLElement) ||
      !(statusLabel instanceof HTMLElement) ||
      !(statusMeta instanceof HTMLElement) ||
      !(progress instanceof HTMLElement) ||
      !(cta instanceof HTMLElement)
    )
      return;

    const hot = function (e) {
      e.preventDefault();
      zone.classList.add("drag-hover");
    };
    const cool = function () {
      zone.classList.remove("drag-hover");
    };
    zone.addEventListener("dragenter", hot);
    zone.addEventListener("dragover", hot);
    zone.addEventListener("dragleave", cool);

    function setStatus(state, label, meta) {
      status.hidden = false;
      status.dataset.state = state;
      statusLabel.textContent = label;
      statusMeta.textContent = meta || "";
      progress.classList.remove("indeterminate");
      if (state === "uploading" || state === "queued" || state === "running") {
        progress.classList.add("indeterminate");
      }
      cta.innerHTML = "";
    }

    function fail(message) {
      setStatus("error", "error", "");
      const msg = document.createElement("div");
      msg.className = "job-status-error";
      msg.textContent = message;
      cta.appendChild(msg);
      const a = document.createElement("a");
      a.href = partnerHref;
      a.target = "_blank";
      a.rel = "noopener";
      a.className = "btn btn-secondary";
      a.textContent = "Apply as design partner →";
      cta.appendChild(a);
    }

    async function ping() {
      try {
        const r = await fetch(apiBase + "/healthz", { method: "GET" });
        if (!r.ok) return false;
        const j = await r.json();
        return j && j.ok === true;
      } catch (_) {
        return false;
      }
    }

    // R2 direct upload: ask our Vercel Function for a presigned PUT URL,
    // stream the file body directly to Cloudflare R2 (no Vercel hop, no
    // mixed-content block), then hand the resulting GET URL to the
    // optimize API as `source_url`. This bypasses every payload-size
    // bottleneck and avoids egress fees on downloads.
    async function requestUploadUrl(file) {
      const r = await fetch("/api/upload-url", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({
          filename: file.name,
          contentType: file.type || "application/octet-stream",
          size: file.size,
        }),
      });
      if (!r.ok) {
        const text = await r.text();
        throw new Error("POST /api/upload-url " + r.status + " — " + text);
      }
      return await r.json();
    }

    async function uploadToR2(uploadUrl, file, contentType) {
      const r = await fetch(uploadUrl, {
        method: "PUT",
        headers: { "content-type": contentType },
        body: file,
      });
      if (!r.ok) {
        const text = await r.text();
        throw new Error("PUT R2 " + r.status + " — " + text);
      }
    }

    async function createJob(filename, sizeBytes, sourceUrl) {
      const r = await fetch(apiBase + "/v1/jobs", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({
          preset: "web-mobile",
          filename: filename,
          size_bytes: sizeBytes,
          source_url: sourceUrl,
        }),
      });
      if (!r.ok) {
        const text = await r.text();
        throw new Error("POST /v1/jobs " + r.status + " — " + text);
      }
      return await r.json();
    }

    async function pollJob(jobId) {
      const r = await fetch(apiBase + "/v1/jobs/" + jobId, { method: "GET" });
      if (!r.ok) {
        const text = await r.text();
        throw new Error("GET /v1/jobs/" + jobId + " " + r.status + " — " + text);
      }
      return await r.json();
    }

    function renderJob(job) {
      const s = job.status;
      if (s === "awaiting-upload") {
        setStatus("uploading", "uploading", "preparing");
      } else if (s === "uploading") {
        setStatus("uploading", "uploading", "API fetching from R2");
      } else if (s === "queued") {
        setStatus("queued", "queued", "modal cold-start in flight");
      } else if (s === "running") {
        setStatus("running", "running", "splatforge optimize");
      } else if (s === "done") {
        setStatus("done", "done", "");
        if (job.output_url) {
          const a = document.createElement("a");
          a.href = job.output_url;
          a.target = "_blank";
          a.rel = "noopener";
          a.className = "btn btn-primary";
          a.textContent = "Download optimized.gltf →";
          cta.appendChild(a);
        }
      } else if (s === "error") {
        fail(job.error || "optimize failed");
      }
    }

    function waitFor(jobId) {
      return new Promise(function (resolve, reject) {
        const started = Date.now();
        const tick = async function () {
          try {
            const job = await pollJob(jobId);
            renderJob(job);
            if (job.status === "done" || job.status === "error") {
              resolve(job);
              return;
            }
            if (Date.now() - started > 10 * 60 * 1000) {
              reject(new Error("timed out waiting for job (10 min)"));
              return;
            }
            setTimeout(tick, 2000);
          } catch (err) {
            reject(err);
          }
        };
        tick();
      });
    }

    async function handleFile(file) {
      const supportedExts = [".ply", ".spz", ".gltf", ".glb", ".splat"];
      const lower = file.name.toLowerCase();
      const ok = supportedExts.some(function (ext) {
        return lower.endsWith(ext);
      });
      if (!ok) {
        headline.textContent = "Unsupported file type.";
        body.innerHTML =
          'Supported: <code>' +
          supportedExts.join("</code>, <code>") +
          "</code>. Choose a different file.";
        return;
      }
      headline.textContent = "Reaching the hosted API…";
      body.innerHTML =
        "Registering <code>" + file.name + "</code> with the optimize queue";
      setStatus("uploading", "uploading", "creating job");

      try {
        const reachable = await ping();
        if (!reachable) throw new Error("/healthz did not return ok");
        // 1. Get a presigned R2 PUT URL.
        setStatus("uploading", "uploading", "signing upload URL");
        const signed = await requestUploadUrl(file);
        // 2. Stream the file body directly to R2 (no proxy).
        const sizeKb = Math.round(file.size / 1024);
        setStatus("uploading", "uploading",
                  "streaming " + sizeKb + " KB to R2");
        await uploadToR2(signed.uploadUrl, file, signed.contentType);
        // 3. Hand the matching GET URL to the optimize API.
        setStatus("uploading", "uploading", "creating job");
        const job = await createJob(file.name, file.size, signed.sourceUrl);
        headline.textContent = "Optimizing " + file.name;
        body.innerHTML = "Job " + job.id;
        await waitFor(job.id);
      } catch (err) {
        headline.textContent = "Something went wrong.";
        body.innerHTML = "The hosted API may be cold or the file too large.";
        const apiStatus = document.querySelector("[data-api-status]");
        const apiStatusLbl = document.querySelector("[data-api-status-label]");
        if (apiStatus && apiStatusLbl) {
          apiStatus.classList.add("offline");
          apiStatusLbl.textContent = "offline";
        }
        fail((err && err.message) ? err.message : String(err));
      }
    }

    zone.addEventListener("drop", function (e) {
      e.preventDefault();
      cool();
      const file =
        e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
      if (file) void handleFile(file);
    });
    input.addEventListener("change", function () {
      const file = input.files && input.files[0];
      if (file) void handleFile(file);
    });
  })();
</script>
