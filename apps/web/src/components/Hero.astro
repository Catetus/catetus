---
import { splatbench } from "../lib/splatbench";

const githubUrl = "https://github.com/Catetus/catetus";
const version = splatbench.catetusVersion;
const viewerSrc = "/am15/hero-embed.html?url=/hero-scene-v3/bonsai.splat&local=1";
---

<section class="hero hero-wide" aria-labelledby="hero-title">
  <div class="hero-text">
    <div class="hero-eyebrow">Catetus · v{version} · Apache-2.0</div>
    <h1 id="hero-title" class="hero-title">
      Make Gaussian Splats <span class="grad">production&#8209;ready.</span>
    </h1>
    <p class="hero-sub">
      Open-source CLI and viewer SDK featuring dual-engine optimization. Repack assets
      <strong>22× in 730ms</strong> with our CPU-based Classic Rust Engine, or scale to
      <strong>up to 108× total compression</strong> with our new Neural HAC++ Optimizer.
    </p>
    <div class="hero-ctas">
      <a class="btn btn-primary" href="#try">
        Try it on your splat <span aria-hidden="true">→</span>
      </a>
      <a class="btn btn-ghost" href="#leaderboard">See SplatBench →</a>
      <a class="hero-link" href={githubUrl} target="_blank" rel="noreferrer noopener">
        or browse the source on GitHub ↗
      </a>
    </div>

    <div class="trust-strip" aria-label="Project signals">
      <span class="item"><span aria-hidden="true">●</span>&nbsp;Standards-aligned</span>
      <span class="sep"></span>
      <span class="item">glTF · SPZ · USD-bound</span>
      <span class="sep"></span>
      <span class="item">deterministic</span>
    </div>
  </div>

  <div class="splat-stage splat-stage-large" aria-hidden="true" data-hero-stage>
    <iframe
      class="hero-iframe"
      src={viewerSrc}
      loading="lazy"
      title="3D Gaussian splat — bonsai scene"
      sandbox="allow-scripts allow-same-origin"></iframe>
    <div class="splat-frame"></div>
    <div class="splat-caption">
      <span class="live">live</span>
      <span class="tabular">bonsai · 1.15M splats · 37 MB</span>
    </div>
  </div>
</section>

<style>
  /* Two-column layout. Text on the left, viewer on the right, with a max
     width so the viewer doesn't dominate on ultra-wide screens. */
  .hero-wide {
    display: grid;
    grid-template-columns: minmax(320px, 1fr) minmax(0, 1fr);
    gap: 48px;
    align-items: center;
    max-width: 1280px;
    margin: 0 auto;
  }
  @media (max-width: 1024px) {
    .hero-wide { grid-template-columns: 1fr; gap: 24px; }
  }
  .splat-stage-large {
    position: relative;
    aspect-ratio: 4 / 3;
    width: 100%;
    max-height: 640px;
    overflow: hidden;
    border-radius: 12px;
    background: #000;
    isolation: isolate;
  }
  .hero-iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    background: #000;
  }
  .splat-stage-large .splat-frame {
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: 12px;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
    z-index: 2;
  }
  .splat-stage-large .splat-caption {
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 12px;
    display: flex;
    justify-content: space-between;
    gap: 16px;
    font: 12px/1.4 ui-monospace, monospace;
    color: rgba(220, 230, 240, 0.85);
    background: rgba(0, 0, 0, 0.55);
    padding: 6px 10px;
    border-radius: 6px;
    pointer-events: none;
    z-index: 3;
  }
</style>
