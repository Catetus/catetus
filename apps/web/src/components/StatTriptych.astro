---
// Three big numbers under the hero, each justified with a one-line blurb.
//
// All three are absolute, customer-visible facts about the SF tier (the codec
// that ships today). No competitor comparisons, no negative percentages, no
// "coming soon" — the deeper /vs section and SplatBench page carry the
// head-to-head detail for visitors who want it.
//
// Numbers sourced from:
//   SplatForge/benches/reports/canonical-11.{md,json} — 11-scene cross-scene
//     leaderboard, bonsai row in particular for the absolute MB/PSNR pair.
//
// Tier framing:
//   - SF tier (shipping today): 11/11 scenes encode at an avg 19.8x
//     compression ratio (308.7 MB raw bonsai -> 18.65 MB SF, 47.07 dB PSNR).
//   - Wall clock: ~730 ms single-threaded CPU encode for bonsai
//     (splatbench-v3 measurement, unchanged from prior landing copy).

// SF tier — average compression across the canonical-11 corpus
const sfRatioAvg = 19.8;              // canonical-11.md compression_ratio_mean
const sfWinsTotal = 11;               // 11/11 scenes pass the strict gate
const corpusRawMb = 8026;             // sum of input_ply_bytes across 11 scenes (decimal MB)
const corpusOutMb = 396;              // sum of encoded_total_bytes across 11 scenes (decimal MB)

// Bonsai — concrete reference scene (also the one rendering in the hero iframe)
const bonsaiOutMb = 18.7;             // 18.65 MB SF output
const bonsaiInputMb = 309;            // 308.7 MB raw 3DGS PLY
const bonsaiPsnr = 47.07;             // gsplat 72-view orbit, SH3
const bonsaiSsim = 0.9991;            // same protocol

// Wall clock — SF tier single-threaded CPU encode on bonsai
const optimizeMs = 730;
---

<section class="stat-strip" aria-label="Headline numbers">
  <div class="stat">
    <div class="stat-label">Bonsai scene · live above</div>
    <div class="stat-value tabular">{bonsaiOutMb}<span class="unit">MB</span></div>
    <p class="stat-blurb">
      <span class="tabular">{bonsaiInputMb} MB</span> raw 3DGS &rarr; <span class="tabular">{bonsaiOutMb} MB</span>
      glTF + SPZ, rendered at <strong class="tabular">{bonsaiPsnr.toFixed(2)} dB</strong> /
      <strong class="tabular">{bonsaiSsim.toFixed(4)}</strong> SSIM on a 72-view orbit.
    </p>
  </div>
  <div class="stat">
    <div class="stat-label">Canonical-11 corpus</div>
    <div class="stat-value tabular">{sfRatioAvg.toFixed(1)}<span class="unit">×</span></div>
    <p class="stat-blurb">
      Average compression across <span class="tabular">{sfWinsTotal}</span> production scenes
      (<span class="tabular">{corpusRawMb.toLocaleString()} MB</span> &rarr;
      <span class="tabular">{corpusOutMb} MB</span>). Every scene reproducible byte-for-byte
      from a BLAKE3 hash of its IR.
    </p>
  </div>
  <div class="stat">
    <div class="stat-label">CPU encode · single core</div>
    <div class="stat-value tabular">{optimizeMs}<span class="unit">ms</span></div>
    <p class="stat-blurb">
      Bonsai encodes in under a second on one CPU core, no GPU required. Outputs
      are deterministic and validate against the glTF + SPZ specifications.
    </p>
  </div>
</section>
