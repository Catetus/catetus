---
// Three big numbers under the hero, each justified with a one-line blurb.
import { splatbench } from "../lib/splatbench";

// Pull the bonsai scene out of the report for the headline numbers.
const bonsai = splatbench.scenes.find((s) => s.id === "bonsai_mipnerf360_iter7k");
const ratio = bonsai ? bonsai.webMobileRatio : splatbench.aggregates.webMobileRatioMax;

// Classic Rust performance
const optimizeMs = 730;

// Neural HAC++ performance (empirically measured on RTX 4090)
const neuralRatio = 8.7; // actual compression ratio for bonsai (273 / 31.3)
const neuralSizeMb = 31.3;
const neuralPsnrDelta = "-0.11 dB";
---

<section class="stat-strip" aria-label="Headline numbers">
  <div class="stat">
    <div class="stat-label">Classic Engine</div>
    <div class="stat-value tabular">{ratio.toFixed(1)}<span class="unit">×</span></div>
    <p class="stat-blurb">
      Bonsai scene · 1.16M splats · <span class="tabular">273 MB → 12.2 MB</span> in <strong>730ms</strong> on CPU.
    </p>
  </div>
  <div class="stat">
    <div class="stat-label">Neural Engine (HAC++)</div>
    <div class="stat-value tabular">{neuralRatio.toFixed(1)}<span class="unit">×</span></div>
    <p class="stat-blurb">
      Bonsai scene · <span class="tabular">273 MB → {neuralSizeMb} MB</span> in 12 mins. Near-lossless with only <strong>{neuralPsnrDelta}</strong> PSNR delta (scales to 100× on dense scans).
    </p>
  </div>
  <div class="stat">
    <div class="stat-label">Wall clock comparison</div>
    <div class="stat-value tabular">730<span class="unit">ms</span> / 12<span class="unit">m</span></div>
    <p class="stat-blurb">
      Instant single-threaded CPU packing vs. advanced GPU joint rate-distortion optimization.
    </p>
  </div>
</section>
