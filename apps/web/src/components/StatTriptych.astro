---
// Three big numbers under the hero, each justified with a one-line blurb.
import { splatbench } from "../lib/splatbench";

// Pull the bonsai scene out of the report for the headline numbers.
const bonsai = splatbench.scenes.find((s) => s.id === "bonsai_mipnerf360_iter7k");
const ratio = bonsai ? bonsai.webMobileRatio : splatbench.aggregates.webMobileRatioMax;

// Classic Rust performance
const optimizeMs = 730;

// Perceptual Engine (E7 SH-strip + WD-R bake): measured cross-scene on bonsai (matte),
// bicycle (outdoor), and Sweet Corals tile (dense underwater). All three scenes hit
// the same ~73% byte reduction; matte content also gains 6% LPIPS. Held-out validated.
const perceptualRatio = 22.7;     // cumulative vs raw PLY on bonsai
const perceptualSizeMb = 13.3;    // SF preset + E7 SH-strip + WD-R bake
const perceptualLpipsDelta = "-6%"; // matte scenes; outdoor/textured = neutral

// HAC++ lzma (hosted) — premium GPU preset on Scaffold-GS bundles. Kept as a third
// reference but no longer the headline; the Perceptual Engine is the cross-scene
// preset most customers run.
---

<section class="stat-strip" aria-label="Headline numbers">
  <div class="stat">
    <div class="stat-label">Classic Engine</div>
    <div class="stat-value tabular">{ratio.toFixed(1)}<span class="unit">×</span></div>
    <p class="stat-blurb">
      Bonsai scene · 1.16M splats · <span class="tabular">273 MB → 12.2 MB</span> in <strong>730ms</strong> on CPU.
    </p>
  </div>
  <div class="stat">
    <div class="stat-label">Perceptual Engine</div>
    <div class="stat-value tabular">{perceptualRatio.toFixed(1)}<span class="unit">×</span></div>
    <p class="stat-blurb">
      Classic Engine + SH-stripped &amp; perceptually retuned · <span class="tabular">273 MB → {perceptualSizeMb} MB</span>. Cross-scene PASS on matte, outdoor, and dense-scan content; <strong>{perceptualLpipsDelta} LPIPS</strong> on matte scenes vs the original full-SH render.
    </p>
  </div>
  <div class="stat">
    <div class="stat-label">Wall clock comparison</div>
    <div class="stat-value tabular">730<span class="unit">ms</span> / 3<span class="unit">m</span></div>
    <p class="stat-blurb">
      Instant single-threaded CPU packing vs. ~3-minute GPU perceptual fine-tune (held-out validated on Mip-NeRF 360 + an underwater coral tile).
    </p>
  </div>
</section>
