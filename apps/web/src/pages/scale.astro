---
// SPDX-License-Identifier: Apache-2.0
//
// /scale — Sweet Corals 119M LODGE live demo (Bet 2 M2 tentpole).
//
// What this page actually proves:
//   * In-browser Gaussian-splat rendering against a 3.2M-splat L5 stream
//     of the 119,824,300-splat Sweet Corals scene, fetched as 33 PLY
//     chunks from Vercel Blob.
//   * The LODGE Phase A.3 streaming runtime (see
//     packages/viewer/src/lodge/) wired to a ComputeDecodePipeline +
//     custom render shim — no bundler, ESM-only, served from
//     /viewer/lodge/index.js.
//
// What it does NOT claim:
//   * "119M live in your browser." L0..L2 don't fit in the browser yet
//     (wgpu maxBufferSize cap + dispatch limit). L5 (3.2M) is the live
//     demo today; L4/L3 are best-effort and may fail on integrated
//     graphics or memory-constrained Macs.
//
// Bench truth (RTX 4090 Laptop, 16 GB VRAM, May 2026):
//   L5 = 14.97 fps  ·  L4 = 5.92 fps  ·  L3 = 1.30 fps
//   L0..L2 require operator-driven 4090 bench (in-flight wgpu-multidispatch
//   unlock + maxBufferSize workaround).
//
// See benches `packages/viewer/bench/results-4090-lodge.json` for the
// raw numbers and `docs/perf/lodge-lod-spec.md` for the runtime spec.

import Base from "../layouts/Base.astro";

const title = "Scale — 119M-splat Sweet Corals · SplatForge";
const description =
  "Live in-browser stream of a 3.2M-splat LOD level (L5) of the 119,800,000-splat Sweet Corals scene. LODGE runtime, chunked HTTP, WebGPU compute-decode.";

// L4 + L5 manifest URL — published 2026-05-15 from the 4090 LODGE
// chunker output via apps/web/scripts/publish-sweet-corals-l5.py.
// Stable per-blob (Vercel Blob inserts a random suffix per object).
// To add L3/L2/L1/L0:
//   1. Run the publish script on the 4090 with `--level 3` etc.
//   2. Replace this URL with the returned `manifest_url`.
const lodgeManifestUrl =
  "https://xmcqr5nqjygbqjqw.public.blob.vercel-storage.com/samples/sweet-corals.lodge/manifest-l4-l5-QevCTqvCPEvNGoZKyeEUn9iYFWgEoX.json";

const githubUrl = "https://github.com/montabano1/SplatForge";
---

<Base title={title} description={description}>
  <nav class="nav" aria-label="Primary">
    <a href="/" class="nav-brand">
      <span class="dot" aria-hidden="true"></span>
      splatforge
    </a>
    <div class="nav-links">
      <a href="/#docs">Quickstart</a>
      <a href="/bench">SplatBench</a>
      <a href="/explore">Explore</a>
      <a href="/scale" aria-current="page">Scale</a>
      <a href="/compare">Compare</a>
      <a href="/#try">Try it</a>
      <a href={githubUrl} target="_blank" rel="noreferrer noopener">GitHub ↗</a>
    </div>
  </nav>

  <header class="scale-hero">
    <div class="scale-hero-eyebrow">LODGE · Phase A.3 · live</div>
    <h1 class="scale-hero-headline">
      <span class="num tabular">119,800,000</span> splats. Streamed.
    </h1>
    <p class="scale-hero-sub">
      One scene — Sweet Corals (CC-BY-4.0, wildflow). Six LOD levels chunked offline.
      Streamed into your browser one PLY at a time. WebGPU compute-decode +
      LODGE eq.4 boundary-blend per frame.
    </p>
    <div class="scale-hero-attrib">
      <span>Corpus:</span>
      <a href="https://wildflow.ai" target="_blank" rel="noreferrer noopener">wildflow.ai</a>
      <span aria-hidden="true">·</span>
      <span>46-tile Sweet Corals merge</span>
      <span aria-hidden="true">·</span>
      <span>119,824,300 splats</span>
      <span aria-hidden="true">·</span>
      <span>CC-BY-4.0</span>
    </div>
  </header>

  <section class="scale-stage" aria-label="Live splat viewer">
    <div class="scale-canvas-wrap" data-canvas-wrap>
      <canvas id="scale-canvas" data-canvas></canvas>
      <div class="scale-status" data-status>
        <div class="scale-status-state" data-status-state>booting</div>
        <div class="scale-status-detail" data-status-detail>checking WebGPU support</div>
        <div class="scale-status-progress">
          <div class="scale-status-bar" data-status-bar></div>
        </div>
      </div>
    </div>
    <aside class="scale-side">
      <div class="scale-card">
        <h2 class="scale-card-title">LOD level</h2>
        <div class="scale-lod-picker" data-lod-picker role="radiogroup" aria-label="LOD level">
          <!-- L2 still OOMs in-browser on most adapters (wgpu maxBufferSize). L0/L1 ride Stage 6+7 multi-page. -->
          <button type="button" class="scale-lod-btn" data-lod="0">
            <span class="scale-lod-name">L0</span>
            <span class="scale-lod-splats">119.8M</span>
            <span class="scale-lod-tip">heavy on M-series Mac</span>
          </button>
          <button type="button" class="scale-lod-btn" data-lod="1">
            <span class="scale-lod-name">L1</span>
            <span class="scale-lod-splats">54.2M</span>
            <span class="scale-lod-tip">heavy on M-series Mac</span>
          </button>
          <button type="button" class="scale-lod-btn" data-lod="2" disabled aria-disabled="true">
            <span class="scale-lod-name">L2</span>
            <span class="scale-lod-splats">28.0M</span>
            <span class="scale-lod-tip">4090-only · in flight</span>
          </button>
          <button type="button" class="scale-lod-btn" data-lod="3">
            <span class="scale-lod-name">L3</span>
            <span class="scale-lod-splats">13.3M</span>
            <span class="scale-lod-tip">heavy on M-series Mac</span>
          </button>
          <button type="button" class="scale-lod-btn" data-lod="4">
            <span class="scale-lod-name">L4</span>
            <span class="scale-lod-splats">7.3M</span>
            <span class="scale-lod-tip">smooth on most laptops</span>
          </button>
          <button type="button" class="scale-lod-btn is-active" data-lod="5" aria-checked="true">
            <span class="scale-lod-name">L5</span>
            <span class="scale-lod-splats">3.2M</span>
            <span class="scale-lod-tip">live demo today</span>
          </button>
        </div>
        <p class="scale-card-foot">
          L5 ships first because it's reproducible on every WebGPU-capable
          browser. L4/L3 are the same runtime, larger payloads.
        </p>
      </div>

      <div class="scale-card">
        <h2 class="scale-card-title">Live stats</h2>
        <dl class="scale-stats">
          <div class="scale-stat">
            <dt>Splat count (active)</dt>
            <dd class="num tabular" data-stat-splats>—</dd>
          </div>
          <div class="scale-stat">
            <dt>Frames per second</dt>
            <dd class="num tabular" data-stat-fps>—</dd>
          </div>
          <div class="scale-stat">
            <dt>Bytes streamed</dt>
            <dd class="num tabular" data-stat-bytes>—</dd>
          </div>
          <div class="scale-stat">
            <dt>Scene total splats</dt>
            <dd class="num tabular">119,824,300</dd>
          </div>
        </dl>
      </div>

      <div class="scale-card scale-card-bench">
        <h2 class="scale-card-title">4090 bench truth</h2>
        <p class="scale-bench-blurb">
          Median fps from
          <a href="https://github.com/montabano1/SplatForge/blob/main/packages/viewer/bench/results-4090-lodge.json"
             target="_blank" rel="noreferrer noopener">
            results-4090-lodge.json
          </a>
          on consumer hardware (RTX 4090 Laptop, 16 GB VRAM):
        </p>
        <ul class="scale-bench-list">
          <li><span>L5 · 3.2M</span> <span class="num tabular">14.97 fps</span></li>
          <li><span>L4 · 7.3M</span> <span class="num tabular">5.92 fps</span></li>
          <li><span>L3 · 13.3M</span> <span class="num tabular">1.30 fps</span></li>
          <li class="is-pending">
            <span>L0–L2</span>
            <span class="num tabular">operator-driven 4090 bench</span>
          </li>
        </ul>
      </div>
    </aside>
  </section>

  <section class="scale-method">
    <h2 id="method" class="section-title">Methodology</h2>
    <div class="scale-method-grid">
      <div>
        <h3>Offline chunker</h3>
        <p>
          The Sweet Corals 46-tile PLY (29.7 GB on disk) is built into a
          6-level LOD pyramid via <code>splatforge lodge build</code> —
          the Phase A.1 chunker. Each level is sliced by Morton code into
          24 MB PLY chunks (~100k splats each for L5).
        </p>
      </div>
      <div>
        <h3>Streaming</h3>
        <p>
          The browser fetches <code>manifest.json</code> first, then
          requests chunks on demand via the LRU-bounded
          <code>LodgeChunkLoader</code>. PLY → SoA decode happens on the
          CPU; the 64-byte-per-splat record is uploaded to a WebGPU
          storage buffer with 256-byte-aligned offsets.
        </p>
      </div>
      <div>
        <h3>LOD selection</h3>
        <p>
          Phase A.3 ships per-frame WGSL <code>cs_lod_select</code> +
          <code>cs_lod_blend</code> kernels that pick chunks by camera
          distance + screen-space size, then modulate per-splat opacity
          across the LODGE eq.4 near/far boundary band.
        </p>
      </div>
      <div>
        <h3>Reproduce</h3>
        <p>
          Bench harness:
          <code>packages/viewer/bench/real-scene-lodge.bench.ts</code>.
          Run on the 4090 via the <code>sf_bench_real</code> schtask — it
          discovers <code>.lodge/</code> directories under
          <code>SF_BENCH_PLY_DIR</code> and writes
          <code>results-4090-lodge.json</code>.
        </p>
      </div>
    </div>
  </section>

  <footer class="scale-footer">
    <span>
      Sweet Corals scan: <a href="https://wildflow.ai" target="_blank" rel="noreferrer noopener">wildflow.ai</a>
      · CC-BY-4.0
    </span>
    <span>
      LODGE runtime: <a href={`${githubUrl}/tree/main/packages/viewer/src/lodge`}>packages/viewer/src/lodge</a>
      · spec: <a href={`${githubUrl}/blob/main/docs/perf/lodge-lod-spec.md`}>docs/perf/lodge-lod-spec.md</a>
    </span>
    <span>Apache-2.0</span>
  </footer>
</Base>

<style is:global>
