  .scale-stage {
    max-width: 1180px;
    margin: 0 auto 56px;
    padding: 0 24px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 20px;
  }
  @media (max-width: 980px) {
    .scale-stage { grid-template-columns: 1fr; }
  }
  .scale-canvas-wrap {
    position: relative;
    aspect-ratio: 16 / 10;
    background: #000;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #223;
