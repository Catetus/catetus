</style>

<script type="module" define:vars={{ lodgeManifestUrl }}>
  // SPDX-License-Identifier: Apache-2.0
  //
  // Self-contained LODGE viewer mount. Wires:
  //   * @splatforge/viewer LodgeChunkLoader (chunk fetch + decode + LRU)
  //   * @splatforge/viewer ComputeDecodePipeline (WGSL decode + sort + project)
  //   * Inline render WGSL (one quad per splat, EWA fragment shader)
  //
  // We do NOT use SplatForgeViewer here because SplatForgeViewer expects a
  // legacy gltf-style manifest, not a LODGE pyramid. The LODGE runtime is
  // a different code path inside the same package.

  const els = {
    canvas: document.querySelector("[data-canvas]"),
    status: document.querySelector("[data-status]"),
    state: document.querySelector("[data-status-state]"),
    detail: document.querySelector("[data-status-detail]"),
    bar: document.querySelector("[data-status-bar]"),
    splats: document.querySelector("[data-stat-splats]"),
    fps: document.querySelector("[data-stat-fps]"),
    bytes: document.querySelector("[data-stat-bytes]"),
    lodPicker: document.querySelector("[data-lod-picker]"),
  };

  const state = {
    pipeline: null,
    loader: null,
    manifest: null,
    device: null,
    canvasCtx: null,
    renderPipeline: null,
    bindGroup: null,
    uniformBuffer: null,
    raf: 0,
    fps: 0,
    bytesStreamed: 0,
    activeSplats: 0,
    yaw: 0,
    targetLevel: 5,
    loading: false,
    loadGen: 0,
  };

  function fmt(n) {
    if (!Number.isFinite(n)) return "—";
    if (n >= 1e9) return (n / 1e9).toFixed(2) + "G";
    if (n >= 1e6) return (n / 1e6).toFixed(2) + "M";
    if (n >= 1e3) return (n / 1e3).toFixed(1) + "k";
    return Math.round(n).toString();
  }
  function fmtBytes(n) {
    if (n >= 1e9) return (n / 1e9).toFixed(2) + " GB";
    if (n >= 1e6) return (n / 1e6).toFixed(1) + " MB";
    if (n >= 1e3) return (n / 1e3).toFixed(1) + " KB";
    return n + " B";
  }

  function setStatus(s, detail, pct) {
    if (els.state) els.state.textContent = s;
    if (els.detail && detail !== undefined) els.detail.textContent = detail;
    if (els.bar && pct !== undefined) els.bar.style.width = `${Math.max(0, Math.min(100, pct))}%`;
    if (els.status) els.status.dataset.state = s === "ready" ? "ready" : s === "error" ? "error" : "loading";
  }

  function updateStats() {
    if (els.splats) els.splats.textContent = fmt(state.activeSplats);
    if (els.fps) els.fps.textContent = state.fps ? state.fps.toFixed(1) : "—";
    if (els.bytes) els.bytes.textContent = fmtBytes(state.bytesStreamed);
  }

  // Render WGSL — same per-instance attrs as packages/viewer/src/renderer/webgpu.ts
  // (clipPos, cov, color), but inlined so this page stays self-contained.
  const RENDER_WGSL = /* wgsl */ `
    struct Instance {
      @location(0) clipPos : vec4<f32>,
      @location(1) cov     : vec4<f32>,
      @location(2) color   : vec4<f32>,
    };
    struct U {
      viewportSize : vec2<f32>,
      _pad         : vec2<f32>,
    };
    @group(0) @binding(0) var<uniform> u : U;
    struct VsOut {
      @builtin(position) clip : vec4<f32>,
      @location(0) offset : vec2<f32>,
      @location(1) cov    : vec3<f32>,
      @location(2) color  : vec4<f32>,
    };
    @vertex
    fn vs_main(@builtin(vertex_index) vid : u32, inst : Instance) -> VsOut {
      let corners = array<vec2<f32>, 4>(
        vec2<f32>(-1.0, -1.0), vec2<f32>( 1.0, -1.0),
        vec2<f32>(-1.0,  1.0), vec2<f32>( 1.0,  1.0),
      );
      let c = corners[vid];
      let radiusPx = max(inst.cov.w, 1.0);
      let ndcOffset = c * radiusPx * 2.0 / u.viewportSize;
      var out : VsOut;
      out.clip = vec4<f32>(
        inst.clipPos.x + ndcOffset.x,
        inst.clipPos.y + ndcOffset.y,
        clamp(inst.clipPos.z, 0.0, 1.0),
        1.0,
      );
      out.offset = c * radiusPx;
      out.cov = inst.cov.xyz;
      out.color = inst.color;
      return out;
    }
    @fragment
    fn fs_main(in : VsOut) -> @location(0) vec4<f32> {
      let c00 = in.cov.x;
      let c01 = in.cov.y;
      let c11 = in.cov.z;
      let det = max(c00 * c11 - c01 * c01, 1e-6);
      let inv00 =  c11 / det;
      let inv01 = -c01 / det;
      let inv11 =  c00 / det;
      let d = in.offset;
      let power = -0.5 * (d.x * d.x * inv00 + 2.0 * d.x * d.y * inv01 + d.y * d.y * inv11);
      if (power > 0.0) { discard; }
      let alpha = clamp(in.color.a * exp(power), 0.0, 0.999);
      if (alpha < 1.0 / 255.0) { discard; }
      return vec4<f32>(in.color.rgb * alpha, alpha);
    }
  `;

  function bboxCenter(b) { return [(b[0][0] + b[1][0]) * 0.5, (b[0][1] + b[1][1]) * 0.5, (b[0][2] + b[1][2]) * 0.5]; }
  function bboxRadius(b) {
    const dx = b[1][0] - b[0][0], dy = b[1][1] - b[0][1], dz = b[1][2] - b[0][2];
    return 0.5 * Math.hypot(dx, dy, dz);
  }
  function orbitPose(bbox, yaw, aspect) {
    const c = bboxCenter(bbox);
    const r = Math.max(bboxRadius(bbox), 0.001) * 2.5;
    const elev = (20 * Math.PI) / 180;
    const cy = Math.cos(elev), sy = Math.sin(elev);
    return {
      position: [c[0] + r * cy * Math.sin(yaw), c[1] + r * sy, c[2] + r * cy * Math.cos(yaw)],
      target: c, up: [0, 1, 0],
      fovY: (60 * Math.PI) / 180, aspect, near: 0.01, far: r * 10,
    };
  }

  async function bootWebGPU() {
    if (!("gpu" in navigator)) {
      setStatus("error", "your browser does not expose navigator.gpu — Chrome 113+, Edge 113+, or Safari Tech Preview required");
      return null;
    }
    const adapter = await navigator.gpu.requestAdapter({ powerPreference: "high-performance" });
    if (!adapter) {
      setStatus("error", "navigator.gpu.requestAdapter() returned null — no compatible adapter");
      return null;
    }
    // Stage 6 (sf-154): expose the adapter's full per-binding ceiling
    // (typically 2 GiB by WebGPU spec on desktop adapters; ~256 MB on
    // Mac default). The viewer's BufferPager handles per-buffer caps by
    // splitting the decoded splat buffer into N pages, so we want the
    // largest possible per-binding budget here. 4 GiB requested even
    // though the spec caps maxStorageBufferBindingSize at 2 GiB-1 — the
    // adapter clamps as needed.
    const cap = adapter.limits.maxStorageBufferBindingSize ?? (256 * 1024 * 1024);
    const bufCap = adapter.limits.maxBufferSize ?? (256 * 1024 * 1024);
    const device = await adapter.requestDevice({
      requiredLimits: {
        maxStorageBufferBindingSize: cap,
        maxBufferSize: bufCap,
      },
    });
    return device;
  }

  function configureCanvas(device) {
    const ctx = els.canvas.getContext("webgpu");
    const format = navigator.gpu.getPreferredCanvasFormat();
    ctx.configure({ device, format, alphaMode: "premultiplied" });
    return { ctx, format };
  }

  function buildRenderPipeline(device, format) {
    const module = device.createShaderModule({ code: RENDER_WGSL });
    const bindLayout = device.createBindGroupLayout({
      entries: [{ binding: 0, visibility: GPUShaderStage.VERTEX, buffer: { type: "uniform" } }],
    });
    const layout = device.createPipelineLayout({ bindGroupLayouts: [bindLayout] });
    const pipeline = device.createRenderPipeline({
      layout,
      vertex: {
        module, entryPoint: "vs_main",
        buffers: [{
          arrayStride: 12 * 4, stepMode: "instance",
          attributes: [
            { shaderLocation: 0, offset: 0, format: "float32x4" },
            { shaderLocation: 1, offset: 16, format: "float32x4" },
            { shaderLocation: 2, offset: 32, format: "float32x4" },
          ],
        }],
      },
      fragment: {
        module, entryPoint: "fs_main",
        targets: [{
          format,
          blend: {
            color: { srcFactor: "one", dstFactor: "one-minus-src-alpha", operation: "add" },
            alpha: { srcFactor: "one", dstFactor: "one-minus-src-alpha", operation: "add" },
          },
        }],
      },
      primitive: { topology: "triangle-strip" },
    });
    const uniformBuffer = device.createBuffer({
      size: 16, usage: GPUBufferUsage.UNIFORM | GPUBufferUsage.COPY_DST,
    });
    const bindGroup = device.createBindGroup({
      layout: bindLayout,
      entries: [{ binding: 0, resource: { buffer: uniformBuffer } }],
    });
    return { pipeline, bindGroup, uniformBuffer };
  }

  async function loadLevel(level) {
    // Bump the load generation so any in-flight previous-level fetch can
    // notice it's stale and short-circuit. This is the minimal "abort
    // previous load" semantics without rewriting LodgeChunkLoader to
    // accept an AbortSignal.
    const gen = ++state.loadGen;
    state.loading = true;
    setStatus("loading", `streaming L${level} chunks…`, 0);

    // Re-create the compute pipeline whenever the level changes — capacity
    // depends on level splat count, and we want a fresh decoded-splat
    // buffer.
    //
    // The published manifest may contain only a subset of LOD levels (we
    // only uploaded L5 chunks to Vercel Blob in the first pass). Find the
    // entry by `level` ID; fall back to a graceful "not published yet" if
    // it's missing. The chunk-loader's `loadLevel(idx)` indexes the
    // levels[] array, so we need to convert the ID to its array index.
    const lvlIdx = state.manifest.levels.findIndex((l) => l.level === level);
    const lvl = lvlIdx >= 0 ? state.manifest.levels[lvlIdx] : null;
    if (!lvl) {
      setStatus(
        "error",
        `L${level} not published yet (only L5 hosted today; L0..L4 require larger Vercel Blob quota or a CDN with HTTP range)`,
      );
      state.loading = false;
      return;
    }
    const numChunks = lvl.chunks.length;
    const capacity = lvl.splatCount + numChunks * 3;
    if (state.pipeline) state.pipeline.destroy();
    state.pipeline = new state.ComputeDecodePipeline({ device: state.device, capacity });

    state.loader = new state.LodgeChunkLoader(state.manifest, {
      baseUrl: lodgeManifestUrl, // chunk paths are absolute URLs in this manifest
      pipeline: state.pipeline,
      memoryBudgetBytes: 1024 * 1024 * 1024, // 1 GB cap — well under premise's 5 GB local cap
    });

    state.bytesStreamed = 0;
    let loaded = 0;
    const total = lvl.chunks.length;
    // Drive loadLevel manually so we can update progress per chunk.
    // The cleanest way: wrap fetcher to count bytes + tick progress.
    const realFetch = window.fetch.bind(window);
    state.loader.fetcher = async (url) => {
      // Abort the in-flight fetch if a newer loadLevel() superseded us.
      if (gen !== state.loadGen) throw new Error(`load_superseded_by_l${state.targetLevel}`);
      const r = await realFetch(url);
      if (gen !== state.loadGen) throw new Error(`load_superseded_by_l${state.targetLevel}`);
      if (!r.ok) throw new Error(`HTTP ${r.status} for ${url}`);
      const ab = await r.arrayBuffer();
      if (gen !== state.loadGen) throw new Error(`load_superseded_by_l${state.targetLevel}`);
      state.bytesStreamed += ab.byteLength;
      loaded += 1;
      setStatus("loading", `chunk ${loaded}/${total} · ${fmtBytes(state.bytesStreamed)} · L${level}`, (loaded / total) * 100);
      updateStats();
      return new Uint8Array(ab);
    };

    try {
      const cam = orbitPose(state.manifest.bbox, state.yaw, els.canvas.width / els.canvas.height);
      await state.loader.loadLevel(lvlIdx, cam.position);
      if (gen !== state.loadGen) return; // superseded — newer load owns the UI
      state.activeSplats = state.pipeline.splatCount;
      updateStats();
      setStatus("ready", `L${level} live · ${fmt(state.activeSplats)} splats · ${fmtBytes(state.bytesStreamed)} streamed`, 100);
    } catch (err) {
      if (gen !== state.loadGen) return; // newer load owns the UI; swallow abort
      console.error(err);
      setStatus("error", String(err?.message || err).slice(0, 200));
    } finally {
      if (gen === state.loadGen) state.loading = false;
    }
  }

  function resizeCanvas() {
    const wrap = els.canvas.parentElement;
    const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
    els.canvas.width = Math.max(1, Math.floor(wrap.clientWidth * dpr));
    els.canvas.height = Math.max(1, Math.floor(wrap.clientHeight * dpr));
  }

  function startRenderLoop() {
    let lastT = performance.now();
    let frames = 0;
    let acc = 0;
    function tick() {
      state.raf = requestAnimationFrame(tick);
      if (!state.pipeline || state.pipeline.splatCount === 0) return;
      const now = performance.now();
      const dt = Math.min(0.1, (now - lastT) / 1000);
      lastT = now;
      acc += dt; frames += 1;
      if (acc >= 0.5) {
        state.fps = frames / acc;
        frames = 0; acc = 0;
        // Keep activeSplats live while streaming so the user sees the
        // pipeline grow chunk-by-chunk instead of jumping at the end.
        state.activeSplats = state.pipeline.splatCount;
        updateStats();
      }
      // Slow auto-orbit so the test still captures motion if the user
      // doesn't interact.
      state.yaw += dt * 0.15;

      const w = els.canvas.width, h = els.canvas.height;
      const aspect = w / h;
      const cam = orbitPose(state.manifest.bbox, state.yaw, aspect);
      const { view, viewProj } = state.buildViewProj(cam, aspect);
      const focalY = h / (2 * Math.tan(cam.fovY * 0.5));

      const u = new Float32Array(4); u[0] = w; u[1] = h;
      state.device.queue.writeBuffer(state.uniformBuffer, 0, u);

      const enc = state.device.createCommandEncoder();
      state.pipeline.encode(enc, view, viewProj, [focalY, focalY], [w, h]);
      const tex = state.canvasCtx.getCurrentTexture();
      const pass = enc.beginRenderPass({
        colorAttachments: [{
          view: tex.createView(),
          clearValue: { r: 0.02, g: 0.04, b: 0.08, a: 1 },
          loadOp: "clear", storeOp: "store",
        }],
      });
      pass.setPipeline(state.renderPipeline);
      pass.setBindGroup(0, state.bindGroup);
      pass.setVertexBuffer(0, state.pipeline.instanceBuffer);
      pass.draw(4, state.pipeline.splatCount, 0, 0);
      pass.end();
      state.device.queue.submit([enc.finish()]);
    }
    tick();
  }

  function wireLodPicker() {
    if (!els.lodPicker) return;
    els.lodPicker.addEventListener("click", async (e) => {
      const btn = e.target.closest("[data-lod]");
      if (!btn || btn.disabled) return;
      const level = parseInt(btn.dataset.lod, 10);
      if (level === state.targetLevel && !state.loading) return; // already showing this level
      // Update active state
      els.lodPicker.querySelectorAll("[data-lod]").forEach((b) => {
        b.classList.toggle("is-active", b === btn);
        b.setAttribute("aria-checked", b === btn ? "true" : "false");
      });
      state.targetLevel = level;
      await loadLevel(level);
    });
  }

  async function main() {
    setStatus("loading", "loading viewer modules…", 5);

    // Pull viewer modules from /viewer/ — copied from packages/viewer/dist/
    // by apps/web/scripts/sync-viewer-dist.mjs (runs at build time).
    const [lodgeMod, webgpuMod, mathMod] = await Promise.all([
      import("/viewer/lodge/index.js"),
      import("/viewer/webgpu/index.js"),
      import("/viewer/renderer/math.js"),
    ]);
    state.LodgeChunkLoader = lodgeMod.LodgeChunkLoader;
    state.parseLodgeManifest = lodgeMod.parseLodgeManifest;
    state.ComputeDecodePipeline = webgpuMod.ComputeDecodePipeline;
    state.buildViewProj = mathMod.buildViewProj;

    setStatus("loading", "requesting WebGPU device…", 10);
    const device = await bootWebGPU();
    if (!device) return;
    state.device = device;

    resizeCanvas();
    window.addEventListener("resize", resizeCanvas);

    const { ctx, format } = configureCanvas(device);
    state.canvasCtx = ctx;
    const { pipeline: rp, bindGroup, uniformBuffer } = buildRenderPipeline(device, format);
    state.renderPipeline = rp;
    state.bindGroup = bindGroup;
    state.uniformBuffer = uniformBuffer;

    setStatus("loading", "fetching LODGE manifest…", 15);
    const r = await fetch(lodgeManifestUrl);
    if (!r.ok) {
      setStatus("error", `manifest fetch failed: HTTP ${r.status}`);
      return;
    }
    state.manifest = state.parseLodgeManifest(await r.text());

    // Disable LOD buttons whose level is not in the published manifest.
    // Today only L5 ships in Vercel Blob; L4/L3 are runtime-supported but
    // their chunks aren't uploaded yet (1.7 GB and 3.1 GB respectively).
    const publishedLevels = new Set(state.manifest.levels.map((l) => l.level));
    document.querySelectorAll("[data-lod]").forEach((btn) => {
      const lv = parseInt(btn.dataset.lod, 10);
      if (!publishedLevels.has(lv)) {
        btn.disabled = true;
        btn.setAttribute("aria-disabled", "true");
        const tip = btn.querySelector(".scale-lod-tip");
        if (tip && !tip.textContent.includes("not hosted")) {
          tip.textContent = "not hosted yet";
        }
      }
    });

    wireLodPicker();
    startRenderLoop();
    await loadLevel(state.targetLevel);
  }

  main().catch((err) => {
    console.error(err);
    setStatus("error", String(err?.message || err).slice(0, 200));
  });
</script>
</Base>
