---
// SPDX-License-Identifier: Apache-2.0
//
// /capture — Photos -> Compressed splat, end-to-end.
//
// What this page actually proves:
//   * One Modal app runs the full pipeline: COLMAP sparse reconstruction
//     -> Scaffold-GS 30k training -> QAT-Bundle compression. No PLY
//     required from the customer. A folder of photos is enough.
//   * Measured numbers (bonsai MipNeRF360, 292 photos): COLMAP 5.4 min,
//     Scaffold-GS 30k 37.4 min on A100, QAT-Bundle 6.6 min. Total ~50 min
//     wall, ~$2.10 Modal spend.
//   * Real fidelity preservation: post-QAT PSNR is +0.521 dB ABOVE the
//     pre-QAT Scaffold-GS baseline (33.41 vs 32.89 dB) — the QAT
//     finetune recipe is a net upgrade, not a tradeoff.
//   * 40.5% real PLY-size reduction (130 MB Scaffold-GS PLY -> 77 MB
//     QAT-Bundle PLY).
//
// What it does NOT claim:
//   * Live in-browser training. Training is server-side on Modal A100.
//   * Phone-app capture UX. Today the customer-facing surface is a
//     photos.zip upload; an iOS capture app is out of scope for the
//     v0 ship.
//
// Numbers are pulled from tasks/capture-e2e-demo/out/ in the private
// repo (the 2026-05-16 qat-bundle smoke run, scaffold checkpoint
// trained 2026-05-15). See the /docs/capture-pipeline-spec for the
// invocation contract.

import Base from "../layouts/Base.astro";

const title = "Capture — photos to compressed splat in one Modal run · Catetus";
const description =
  "Upload photos. Get back a compressed Scaffold-GS bundle. COLMAP + Scaffold-GS 30k + QAT-Bundle, end-to-end on Modal A100 in ~50 min for ~$2.";

// Measured bonsai numbers from the 2026-05-16 e2e demo run. Each phase
// shows the actual wall-clock from the production Modal app (the same
// containers a paying customer's job would hit). Cost is computed from
// Modal's A100 rate ($0.000694/sec) + CPU container rate.
const phases = [
  {
    n: 1,
    name: "COLMAP",
    sub: "sparse 3D from photos",
    wallMin: 5.4,
    costUsd: 0.05,  // CPU-only stage on 16-vCPU Modal container
    detail:
      "Feature extraction (CPU SIFT) → exhaustive matcher → mapper. Outputs sparse/0/{cameras,images,points3D}.bin which Scaffold-GS consumes via -s <workspace>. 292 photos, single SIMPLE_PINHOLE intrinsic.",
  },
  {
    n: 2,
    name: "Scaffold-GS",
    sub: "30k iterations · anchor representation",
    wallMin: 37.4,
    costUsd: 1.56,  // A100 @ $0.000694/sec * 2246 sec
    detail:
      "Upstream Scaffold-GS train.py at voxel_size=0.001, ratio=1, n_offsets=10. Trained PSNR 32.83 dB (test eval @ 30k iter). 411k anchors. Output is a 130 MB anchor PLY + 3 MLPs (color, cov, opacity).",
  },
  {
    n: 3,
    name: "QAT-Bundle",
    sub: "quant-aware finetune + encode",
    wallMin: 6.6,
    costUsd: 0.46,  // A100 @ $0.000694/sec * 396 sec + 100 sec render/metrics
    detail:
      "5,000-iter QAT finetune at lr_init=2e-4, lr_final=1e-5, per-channel int4 quant on anchor + offset, constant-strip on opacity. Net PSNR delta: +0.521 dB (33.41 dB post-QAT vs 32.89 dB pre). PLY save: 40.5%.",
  },
  {
    n: 4,
    name: "Upload",
    sub: "Vercel Blob → public URL",
    wallMin: 0.1,
    costUsd: 0.0,
    detail:
      "77 MB output PLY uploaded to Vercel Blob. Customer receives a public URL via API callback identical to the PLY-in / PLY-out flow.",
  },
];
const totalMin = phases.reduce((a, p) => a + p.wallMin, 0);
const totalCost = phases.reduce((a, p) => a + p.costUsd, 0);

// Measured output. URL is the live qat_bundle.ply for bonsai produced
// by the qat_bundle_encode endpoint (scaffold_volume_dir smoke path).
const measuredOutput = {
  ply_url:
    "https://xmcqr5nqjygbqjqw.public.blob.vercel-storage.com/jobs/smoke-bonsai-1778931501/scaffold_qat_bundle-NybC60yL5NtFu0iQzOUQSnD7qFg6Cq.ply",
  ply_bytes: 77_283_072,
  baseline_ply_bytes: 129_899_089,
  baseline_psnr_db: 32.8878,
  finetuned_psnr_db: 33.4089,
  delta_psnr_db: 0.5211,
  ply_save_pct: 40.51,
  anchors: 411_066,
  finetune_iters: 5000,
  n_images: 292,
};

const githubUrl = "https://github.com/Catetus/catetus";
---

<Base title={title} description={description}>
  <nav class="nav" aria-label="Primary">
    <a href="/" class="nav-brand">
      <span class="dot" aria-hidden="true"></span>
      catetus
    </a>
    <div class="nav-links">
      <a href="/#docs">Quickstart</a>
      <a href="/bench">SplatBench</a>
      <a href="/explore">Explore</a>
      <a href="/capture" aria-current="page">Capture</a>
      <a href="/compare">Compare</a>
      <a href={githubUrl} target="_blank" rel="noreferrer noopener">GitHub ↗</a>
    </div>
  </nav>

  <header class="cap-hero">
    <div class="cap-hero-eyebrow">Capture pipeline · end-to-end · measured</div>
    <h1 class="cap-hero-headline">
      Photos in. <span class="num tabular">{Math.round(measuredOutput.ply_bytes / 1e6)}&nbsp;MB</span> compressed splat out.
    </h1>
    <p class="cap-hero-sub">
      One Modal job. Upload a folder of photos; receive a Scaffold-GS
      QAT-Bundle splat. No PLY required, no client-side training, no
      hand-holding through COLMAP. Measured on bonsai (292 photos,
      Mip-NeRF&nbsp;360 sequence): <strong>{totalMin.toFixed(1)} min</strong>
      end-to-end, <strong>${totalCost.toFixed(2)}</strong> Modal spend.
    </p>
    <div class="cap-hero-attrib">
      <span>Source:</span>
      <a href="https://jonbarron.info/mipnerf360/" target="_blank" rel="noreferrer noopener">Mip-NeRF 360 (bonsai)</a>
      <span aria-hidden="true">·</span>
      <span>292 photos</span>
      <span aria-hidden="true">·</span>
      <span>baseline 32.89 dB → 33.41 dB (+0.52 dB)</span>
      <span aria-hidden="true">·</span>
      <span>130 MB → 77 MB (40.5% save)</span>
    </div>
  </header>

  <section class="cap-timeline" aria-label="Pipeline stages">
    <ol class="cap-stage-list">
      {phases.map((p) => (
        <li class="cap-stage">
          <div class="cap-stage-head">
            <span class="cap-stage-n">Stage&nbsp;{p.n}</span>
            <h2 class="cap-stage-name">{p.name}</h2>
            <span class="cap-stage-sub">{p.sub}</span>
          </div>
          <dl class="cap-stage-stats">
            <div class="cap-stage-stat">
              <dt>Wall</dt>
              <dd class="num tabular">{p.wallMin.toFixed(1)} min</dd>
            </div>
            <div class="cap-stage-stat">
              <dt>Modal $</dt>
              <dd class="num tabular">${p.costUsd.toFixed(2)}</dd>
            </div>
          </dl>
          <p class="cap-stage-detail">{p.detail}</p>
        </li>
      ))}
    </ol>
    <div class="cap-totals">
      <div>
        <span>Total wall</span>
        <span class="num tabular">{totalMin.toFixed(1)} min</span>
      </div>
      <div>
        <span>Total Modal spend</span>
        <span class="num tabular">${totalCost.toFixed(2)}</span>
      </div>
      <div>
        <span>PSNR Δ vs Scaffold-GS-baseline</span>
        <span class="num tabular">+{measuredOutput.delta_psnr_db.toFixed(2)} dB</span>
      </div>
      <div>
        <span>PLY size reduction</span>
        <span class="num tabular">{measuredOutput.ply_save_pct.toFixed(1)}%</span>
      </div>
    </div>
  </section>

  <section class="cap-preview" aria-label="Output artifact">
    <h2 class="section-title">The output</h2>
    <div class="cap-preview-grid">
      <div class="cap-preview-card">
        <h3>QAT-Bundle PLY</h3>
        <dl class="cap-preview-stats">
          <div>
            <dt>Anchors</dt>
            <dd class="num tabular">{measuredOutput.anchors.toLocaleString()}</dd>
          </div>
          <div>
            <dt>Final PLY</dt>
            <dd class="num tabular">{(measuredOutput.ply_bytes / 1e6).toFixed(1)} MB</dd>
          </div>
          <div>
            <dt>Baseline PLY</dt>
            <dd class="num tabular">{(measuredOutput.baseline_ply_bytes / 1e6).toFixed(1)} MB</dd>
          </div>
          <div>
            <dt>Baseline PSNR</dt>
            <dd class="num tabular">{measuredOutput.baseline_psnr_db.toFixed(2)} dB</dd>
          </div>
          <div>
            <dt>Post-QAT PSNR</dt>
            <dd class="num tabular">{measuredOutput.finetuned_psnr_db.toFixed(2)} dB</dd>
          </div>
          <div>
            <dt>Finetune iter</dt>
            <dd class="num tabular">{measuredOutput.finetune_iters.toLocaleString()}</dd>
          </div>
        </dl>
        <a class="cap-download-btn" href={measuredOutput.ply_url} download>
          Download bonsai_qat_bundle.ply ({(measuredOutput.ply_bytes / 1e6).toFixed(1)} MB)
        </a>
        <p class="cap-preview-note">
          Single-PLY Scaffold-GS artifact. Drop into any Scaffold-GS
          renderer (Inria reference, gsplat, splat-transform) or
          re-encode through Catetus's web-mobile preset for a
          progressive-streaming bundle.
        </p>
      </div>

      <div class="cap-preview-card">
        <h3>Reproduce</h3>
        <pre class="cap-cli"><code>{`# 1. Pack your photos
zip photos.zip my-photos/*.jpg

# 2. Upload + dispatch (via catetus CLI)
catetus capture submit \\
  --photos photos.zip \\
  --preset catetus-qat-bundle \\
  --out ./out.ply

# 3. Or POST direct to the Modal app
curl -X POST https://montabano1--catetus-capture-enqueue.modal.run/ \\
  -H 'content-type: application/json' \\
  -d '{
    "job_id": "demo-001",
    "preset": "capture-and-compress",
    "blob_url": "<vercel-blob-url>",
    "filename": "photos.zip",
    "inner_preset": "catetus-qat-bundle",
    "training_iters": 30000,
    "callback_url": "<your-webhook>"
  }'`}</code></pre>
        <p class="cap-preview-note">
          Job IDs are customer-supplied; the callback URL receives
          per-phase progress (<code>fetching</code>, <code>colmap</code>,
          <code>training</code>, <code>encoding</code>,
          <code>uploading</code>) and a terminal {`{status, output_url, metrics}`} POST.
        </p>
      </div>
    </div>
  </section>

  <section class="cap-disclaimer" aria-label="When this works">
    <h2 class="section-title">Honest input requirements</h2>
    <p>
      COLMAP is the bottleneck on capture quality. For a successful run
      we recommend:
    </p>
    <ul class="cap-req-list">
      <li><strong>50–500 photos</strong> in a single orbit (more = exhaustive matcher gets quadratic; less = under-constrained).</li>
      <li><strong>60–80% overlap</strong> between adjacent frames. Walk slowly, don't sprint.</li>
      <li><strong>Textured scene.</strong> A bare wall or a glass coffee table will silently fail at the mapper step — we surface this as a structured "too few features matched" error rather than a generic non-zero exit.</li>
      <li><strong>Static scene.</strong> Anything moving (pets, foliage in wind, your hand) introduces ghost-anchor artifacts that Scaffold-GS can't recover from.</li>
      <li><strong>Single camera.</strong> Mixed phones / DSLRs work but COLMAP's intrinsics are fit per-camera-model; one device per session is the happy path.</li>
    </ul>
    <p class="cap-req-foot">
      The MipNeRF360 bonsai input (above) is a benchmark-grade
      sequence — a well-lit, textured indoor scene with a clean
      orbit. Real-world phone captures land at PSNR delta ±2 dB of
      these numbers depending on how closely they match these
      conditions.
    </p>
  </section>

  <section class="cap-cta" aria-label="Try it">
    <div class="cap-cta-card">
      <h2>Run this on your own captures</h2>
      <p>
        The /capture endpoint is gated behind the Design Partner tier
        ($0/mo, capacity-capped) while we baseline real-world phone
        captures. Drop your email + one example zip and we'll wire it
        up.
      </p>
      <a class="cap-cta-btn" href="mailto:sales@catetus.com?subject=Design%20Partner%20tier">Apply for the Design Partner tier →</a>
    </div>
  </section>

  <footer class="cap-footer">
    <span>
      Bonsai scene: <a href="https://jonbarron.info/mipnerf360/" target="_blank" rel="noreferrer noopener">Mip-NeRF 360</a>
      · MIT / Apache-2.0
    </span>
    <span>
      Pipeline source:
      <a href={`${githubUrl}/blob/main/docs/perf/capture-pipeline-spec.md`}>capture-pipeline-spec.md</a>
    </span>
    <span>Catetus · Apache-2.0</span>
  </footer>
</Base>

