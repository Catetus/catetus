---
// /sdk/babylonjs/quickstart — Quickstart for @splatforge/babylon.
//
// Companion to /sdk. Babylon.js v7 loader for SplatForge-optimized
// .glb assets, plus a SceneLoader hook that auto-detects splat
// payloads so existing Babylon scenes pick them up transparently.
import Base from "../../../layouts/Base.astro";

const title = "Babylon.js plugin — SplatForge SDK quickstart";
const description =
  "Babylon.js v7 quickstart for @splatforge/babylon. Install, register the SceneLoader plugin, render a SplatForge-optimized .glb in five minutes.";
---

<Base title={title} description={description}>
  <nav class="nav" aria-label="Primary">
    <a href="/" class="nav-brand">
      <span class="dot" aria-hidden="true"></span>
      splatforge
    </a>
    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/bench">SplatBench</a>
      <a href="/pricing">Pricing</a>
      <a href="/sdk" aria-current="page">SDK</a>
      <a href="https://github.com/montabano1/SplatForge" target="_blank" rel="noreferrer noopener">GitHub ↗</a>
    </div>
  </nav>

  <div class="breadcrumb">
    <a href="/sdk">← SDK overview</a>
  </div>

  <header class="hero hero-sdk">
    <h1>Babylon.js quickstart</h1>
    <p>
      <code>@splatforge/babylon</code> is a Babylon.js v7 SceneLoader
      plugin. It teaches Babylon's <code>SceneLoader.AppendAsync</code>
      to recognize SplatForge-optimized <code>.glb</code> payloads, so
      a Gaussian-Splat scene lights and shadows next to your existing
      Babylon meshes with no glTF fork required.
    </p>
  </header>

  <section class="quickstart">
    <h2>1. Install</h2>
    <pre><code>npm install @babylonjs/core @babylonjs/loaders @splatforge/babylon</code></pre>

    <h2>2. Register the SceneLoader plugin</h2>
    <pre><code set:html={`import "@babylonjs/loaders/glTF";
import { registerSplatForgeLoader } from "@splatforge/babylon";

// Call once during app init.
registerSplatForgeLoader();`} /></pre>

    <h2>3. Load a SplatForge-optimized scene</h2>
    <pre><code set:html={`import { Engine, Scene, ArcRotateCamera, Vector3 } from "@babylonjs/core";
import { SceneLoader } from "@babylonjs/core/Loading/sceneLoader";

const engine = new Engine(canvas, true);
const scene = new Scene(engine);
new ArcRotateCamera("cam", 0, 1, 4, Vector3.Zero(), scene).attachControl();

await SceneLoader.AppendAsync("/assets/", "bonsai.splatforge.glb", scene);
engine.runRenderLoop(() =&gt; scene.render());`} /></pre>

    <p>
      The plugin emits standard Babylon meshes with a custom material
      that draws the splat payload — so picking, shadow maps, and the
      Babylon Inspector all work out of the box.
    </p>

    <h2>4. Issue a license key (above 10k MAU)</h2>
    <p>
      Below 10k MAU per app per month the plugin runs without a key.
      Above the free tier, issue an HMAC-SHA256 JWT bound to your
      <code>Origin</code> domain:
    </p>
    <pre><code set:html={`curl -X POST https://splatforge.dev/api/v1/sdk/license \\
  -H "Authorization: Bearer $SPLATFORGE_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{"origin": "https://your-app.example.com"}'`} /></pre>
    <p>
      Pass the returned token before registering the loader:
    </p>
    <pre><code set:html={`registerSplatForgeLoader({
  licenseKey: import.meta.env.PUBLIC_SPLATFORGE_LICENSE,
});`} /></pre>
  </section>

  <section class="next-steps">
    <h2>Next</h2>
    <ul>
      <li><a href="/sdk">SDK overview &amp; pricing</a></li>
      <li><a href="/pricing">Hosted optimize API pricing</a></li>
      <li><a href="https://github.com/montabano1/SplatForge" target="_blank" rel="noreferrer noopener">Source on GitHub ↗</a></li>
    </ul>
  </section>
</Base>

<style>
  .breadcrumb {
    max-width: 64rem;
    margin: 1.5rem auto 0;
    padding: 0 1.5rem;
    font-size: 0.875rem;
  }
  .breadcrumb a { color: inherit; opacity: 0.7; }
  .quickstart, .next-steps {
    max-width: 64rem;
    margin: 2rem auto;
    padding: 0 1.5rem;
  }
  .quickstart h2, .next-steps h2 { margin-top: 2rem; }
  .quickstart pre {
    overflow-x: auto;
    padding: 1rem;
    background: rgba(255,255,255,0.04);
    border-radius: 0.5rem;
  }
  .next-steps ul { list-style: none; padding: 0; }
  .next-steps li { margin: 0.5rem 0; }
</style>
