---
import Base from "../../layouts/Base.astro";

const title = "SplatForge — QAT-Bundle format (premium tier)";
const description =
  "How to package a Scaffold-GS checkpoint as a SplatForge QAT-Bundle for the premium full-retrain recipe. Includes the required layout, per-scene expectations from the public bench, and what the worker does end-to-end.";

// Per-scene expectations come from the QAT-Scaffold bench column in
// benches/encoders/qat-scaffold-gs/README.md (commit c3387b3). These
// are the canonical numbers we charge against — if a customer's
// bundle returns numbers materially worse than the bench, they should
// reach out so we can debug.
const benchExpectations = [
  { scene: "bonsai",   psnr: "+0.58 dB", save: "40.5%",  note: "best-case (indoor, dense cams)" },
  { scene: "garden",   psnr: "+0.19 dB", save: "40.5%",  note: "high-quality outdoor" },
  { scene: "bicycle",  psnr: "+0.09 dB", save: "40.5%",  note: "challenging outdoor" },
  { scene: "stump",    psnr: "+0.04 dB", save: "33.9%",  note: "outdoor with sky" },
  { scene: "treehill", psnr: "+0.07 dB", save: "33.7%",  note: "outdoor foliage" },
  { scene: "flowers",  psnr: "+0.03 dB", save: "33.8%",  note: "worst-case (close-up, low cam count)" },
];
---

<Base title={title} description={description}>
