{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "@webgpu/types"
    ],
    "strict": true,
    "outDir": "dist-bench",
    "rootDir": ".",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": [
    "bench/**/*.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "src/__tests__/**/*",
    "node_modules",
    "dist"
  ]
}