{
  "name": "@catetus/mcp",
  "version": "1.0.0-alpha.1",
  "description": "Model Context Protocol server for Catetus — SOTA 3DGS compression toolkit. Exposes encode, score_fidelity, predict_quality, recommend_preset, and the SplatBench corpus to any MCP-compatible client.",
  "type": "module",
  "main": "./dist/server-core.js",
  "bin": {
    "catetus-mcp": "./dist/server-stdio.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev:stdio": "tsx src/server-stdio.ts",
    "dev:http": "tsx src/server-http.ts",
    "start:stdio": "node dist/server-stdio.js",
    "start:http": "node dist/server-http.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "smoke": "node dist/server-stdio.js < /dev/null || true",
    "inspector": "npx @modelcontextprotocol/inspector --cli node dist/server-stdio.js --method tools/list"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.19.2",
    "lru-cache": "^10.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "catetus",
    "3dgs",
    "gaussian-splatting",
    "splat",
    "compression",
    "sog",
    "claude",
    "cursor",
    "cline"
  ]
}
